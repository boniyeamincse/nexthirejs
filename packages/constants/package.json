{
  "name": "@nexthire/constants",
  "private": true,
  "version": "0.0.1",
  "description": "Shared constants for NextHire",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.mjs"
    },
    "./countries": {
      "types": "./dist/countries.d.mts",
      "import": "./dist/countries.mjs",
      "require": "./dist/countries.mjs"
    },
    "./currencies": {
      "types": "./dist/currencies.d.mts",
      "import": "./dist/currencies.mjs",
      "require": "./dist/currencies.mjs"
    },
    "./languages": {
      "types": "./dist/languages.d.mts",
      "import": "./dist/languages.mjs",
      "require": "./dist/languages.mjs"
    },
    "./http": {
      "types": "./dist/http.d.mts",
      "import": "./dist/http.mjs",
      "require": "./dist/http.mjs"
    },
    "./auth": {
      "types": "./dist/auth/user-account-status.d.mts",
      "import": "./dist/auth/user-account-status.mjs",
      "require": "./dist/auth/user-account-status.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/countries.ts src/currencies.ts src/languages.ts src/http.ts src/auth/user-account-status.ts --format esm --dts --sourcemap --clean",
    "dev": "tsup src/index.ts --format esm --dts --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "constants",
    "shared"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@nexthire/eslint-config": "workspace:*",
    "eslint": "^9.18.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
