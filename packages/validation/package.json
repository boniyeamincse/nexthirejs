{
  "name": "@nexthire/validation",
  "private": true,
  "version": "0.0.1",
  "description": "Shared validation schemas for NextHire",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.mjs"
    },
    "./common": {
      "types": "./dist/common.d.mts",
      "import": "./dist/common.mjs",
      "require": "./dist/common.mjs"
    },
    "./pagination": {
      "types": "./dist/pagination.d.mts",
      "import": "./dist/pagination.mjs",
      "require": "./dist/pagination.mjs"
    },
    "./auth": {
      "types": "./dist/auth/candidate-registration.d.mts",
      "import": "./dist/auth/candidate-registration.mjs",
      "require": "./dist/auth/candidate-registration.mjs"
    },
    "./assessments": {
      "types": "./dist/assessments/index.d.mts",
      "import": "./dist/assessments/index.mjs",
      "require": "./dist/assessments/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/auth/candidate-registration.ts --format esm --sourcemap --clean && tsc --project tsconfig.build.json && node scripts/emit-dmts.mjs",
    "dev": "tsup src/index.ts --format esm --dts --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "validation",
    "zod",
    "shared"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@nexthire/constants": "workspace:*",
    "@nexthire/types": "workspace:*",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nexthire/eslint-config": "workspace:*",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
