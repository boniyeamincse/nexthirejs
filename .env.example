COMPOSE_PROJECT_NAME=nexthire

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexthire
POSTGRES_USER=nexthire
POSTGRES_PASSWORD=change_this_local_password

REDIS_HOST=localhost
REDIS_PORT=6379

MINIO_ENDPOINT=http://localhost:9000
MINIO_CONSOLE_URL=http://localhost:9001
MINIO_ROOT_USER=nexthire_minio
MINIO_ROOT_PASSWORD=change_this_local_minio_password
MINIO_DEFAULT_BUCKET=nexthire-local

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_WEB_URL=http://localhost:8025
MAIL_FROM_ADDRESS=no-reply@mnexthire.local
MAIL_FROM_NAME=NextHire

# NextHire API
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3001
API_GLOBAL_PREFIX=api
API_DEFAULT_VERSION=1
API_CORS_ORIGINS=http://localhost:3000
API_DOCS_ENABLED=true
API_BODY_LIMIT=1mb

# NextHire Web
NEXT_PUBLIC_APP_NAME=NextHire
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# Redis application connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_COMMAND_TIMEOUT_MS=5000
REDIS_MAX_RETRIES_PER_REQUEST=3

# BullMQ
BULLMQ_PREFIX=nexthire
BULLMQ_DEFAULT_ATTEMPTS=3
BULLMQ_DEFAULT_BACKOFF_MS=1000
BULLMQ_REMOVE_ON_COMPLETE=100
BULLMQ_REMOVE_ON_FAIL=500

# Development-only queue verification endpoint
SYSTEM_QUEUE_TEST_ENABLED=true

# NextHire Auth
AUTH_ACCESS_TOKEN_SECRET=local-dev-secret-min-32-chars!!
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_JWT_ISSUER=nexthire
AUTH_JWT_AUDIENCE=nexthire-api
AUTH_REFRESH_COOKIE_NAME=nexthire_refresh
WEB_APP_URL=http://localhost:3000

# NextHire Database Access
DATABASE_URL=postgresql://nexthire:change_this_local_password@localhost:5432/nexthire?schema=public
DATABASE_HEALTH_TIMEOUT_MS=5000
