  applicantResponse  String?                 @db.Text
  approvedAt         DateTime?
  rejectedAt         DateTime?
  withdrawnAt        DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  user          User                         @relation(fields: [userId], references: [id], onDelete: Restrict)
  expertProfile ExpertProfile                @relation(fields: [expertProfileId], references: [id], onDelete: Restrict)
  documents     ExpertVerificationDocument[]

  @@index([userId, status])
  @@index([status, submittedAt])
  @@index([reviewedById, reviewedAt])
}

model ExpertVerificationDocument {
  id               String                         @id @default(uuid()) @db.Uuid
  applicationId    String                         @db.Uuid
  type             ExpertVerificationDocumentType
  storageKey       String                         @unique @db.VarChar(500)
  originalFileName String                         @db.VarChar(255)
  mimeType         String                         @db.VarChar(120)
  sizeBytes        BigInt
  checksumSha256   String                         @db.VarChar(64)
  uploadedAt       DateTime                       @default(now())
  removedAt        DateTime?
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt

  application ExpertApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, type, removedAt])
}

model ExpertiseArea {
