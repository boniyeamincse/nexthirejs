generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AuditActorType {
  ANONYMOUS
  USER
  SYSTEM
  INTERNAL
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  DENIED
}

model AuditLog {
  id          String         @id @default(uuid()) @db.Uuid
  occurredAt  DateTime       @default(now())
  requestId   String?        @db.VarChar(100)
  actorType   AuditActorType
  actorUserId String?        @db.Uuid
  action      String         @db.VarChar(150)
  targetType  String?        @db.VarChar(100)
  targetId    String?        @db.VarChar(100)
  outcome     AuditOutcome   @default(SUCCESS)
  metadata    Json?
  createdAt   DateTime       @default(now())

  @@index([occurredAt])
  @@index([actorUserId, occurredAt])
  @@index([action, occurredAt])
  @@index([targetType, targetId])
  @@index([requestId])
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DELETED
}

model User {
  id                 String     @id @default(uuid()) @db.Uuid
  email              String     @unique @db.VarChar(320)
  phone              String?    @db.VarChar(20)
  passwordHash       String
  status             UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt    DateTime?
  phoneVerifiedAt    DateTime?
  passwordChangedAt  DateTime?
  deactivatedAt      DateTime?
  deactivationReason String?    @db.VarChar(100)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  roles                   UserRole[]
  sessions                UserSession[]
  emailVerificationTokens EmailVerificationToken[]
  phoneVerificationOtps   PhoneVerificationOtp[]
  passwordResetTokens     PasswordResetToken[]
  candidateProfile        CandidateProfile?
  candidatePreference     CandidatePreference?
  educationRecords        EducationRecord[]
  workExperienceRecords   WorkExperienceRecord[]
  skills                  CandidateSkill[]
  languages               CandidateLanguage[]
  certifications          CandidateCertification[]
  training                CandidateTraining[]
  achievements            CandidateAchievement[]
  professionalLinks       CandidateProfessionalLink[]
  profilePrivacy          CandidateProfilePrivacy?
  shareToken              CandidateProfileShareToken?
  dataExportRequests      CandidateDataExportRequest[]
  assessmentAttempts      AssessmentAttempt[]
  assessmentCertificates  AssessmentCertificate[]
  mfa                     UserMfa?
  mfaRecoveryCodes        MfaRecoveryCode[]
  mfaChallenges           MfaChallenge[]
  mfaTrustedDevices       MfaTrustedDevice[]
  expertProfile           ExpertProfile?
  expertApplications      ExpertApplication[]
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users UserRole[]
}

model UserRole {
  userId     String   @db.Uuid
  roleId     String   @db.Uuid
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([userId, roleId])
  @@index([roleId])
}

enum UserSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
  COMPROMISED
}

model UserSession {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @db.Uuid
  status           UserSessionStatus @default(ACTIVE)
  refreshTokenHash String            @unique @db.VarChar(128)
  tokenFamilyId    String            @db.Uuid
  expiresAt        DateTime
  lastUsedAt       DateTime?
  ipAddress        String?           @db.VarChar(64)
  userAgent        String?           @db.VarChar(512)
  browserName      String?           @db.VarChar(100)
  operatingSystem  String?           @db.VarChar(100)
  deviceType       String?           @db.VarChar(30)
  revokedAt        DateTime?
  revokeReason     String?           @db.VarChar(100)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, lastUsedAt])
  @@index([tokenFamilyId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @db.VarChar(64)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@index([userId])
  @@index([expiresAt])
}

model PhoneVerificationOtp {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  phone     String    @db.VarChar(20)
  otpHash   String    @db.VarChar(64)
  expiresAt DateTime
  consumedAt DateTime?
  attemptCount Int    @default(0)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phone, expiresAt])
  @@index([expiresAt])
}

model CandidateProfile {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @unique @db.Uuid
  fullName             String    @db.VarChar(150)
  professionalHeadline String?   @db.VarChar(160)
  professionalSummary  String?   @db.Text
  dateOfBirth          DateTime? @db.Date
  completionPercentage Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fullName])
}

model Country {
  id                 String   @id @default(uuid()) @db.Uuid
  code               String   @unique @db.Char(2)
  name               String   @db.VarChar(100)
  phoneCode          String   @db.VarChar(10)
  defaultCurrency    String   @db.Char(3)
  defaultTimezone    String   @db.VarChar(100)
  supportedLanguages String[]
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  candidatePreferences CandidatePreference[]

  @@index([isActive, sortOrder])
}

enum WorkMode {
  ONSITE
  HYBRID
  REMOTE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

model CandidatePreference {
  id                       String           @id @default(uuid()) @db.Uuid
  userId                   String           @unique @db.Uuid
  countryId                String           @db.Uuid
  currentCity              String           @db.VarChar(100)
  preferredJobRoles        String[]
  preferredWorkModes       WorkMode[]
  preferredEmploymentTypes EmploymentType[]
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id], onDelete: Restrict)

  @@index([countryId])
}

enum EducationLevel {
  SECONDARY
  HIGHER_SECONDARY
  DIPLOMA
  BACHELOR
  MASTER
  DOCTORATE
  PROFESSIONAL
  OTHER
}

model EducationRecord {
  id                String         @id @default(uuid()) @db.Uuid
  userId            String         @db.Uuid
  educationLevel    EducationLevel
  institutionName   String         @db.VarChar(200)
  qualification     String         @db.VarChar(150)
  fieldOfStudy      String?        @db.VarChar(150)
  startDate         DateTime       @db.Date
  endDate           DateTime?      @db.Date
  currentlyStudying Boolean        @default(false)
  grade             String?        @db.VarChar(100)
  description       String?        @db.Text
  sortOrder         Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@index([userId, startDate])
}

enum SkillLevel {
  BEGINNER
  DEVELOPING
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum LanguageProficiency {
  BASIC
  CONVERSATIONAL
  PROFESSIONAL
  FLUENT
  NATIVE
}

model CandidateSkill {
  id                String     @id @default(uuid()) @db.Uuid
  userId            String     @db.Uuid
  name              String     @db.VarChar(100)
  normalizedName    String     @db.VarChar(100)
  level             SkillLevel
  yearsOfExperience Decimal?   @db.Decimal(4, 1)
  sortOrder         Int        @default(0)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId, sortOrder])
}

model CandidateLanguage {
  id             String              @id @default(uuid()) @db.Uuid
  userId         String              @db.Uuid
  name           String              @db.VarChar(100)
  normalizedName String              @db.VarChar(100)
  speaking       LanguageProficiency
  reading        LanguageProficiency
  writing        LanguageProficiency
  sortOrder      Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId, sortOrder])
}

model WorkExperienceRecord {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String         @db.Uuid
  companyName      String         @db.VarChar(200)
  jobTitle         String         @db.VarChar(150)
  employmentType   EmploymentType
  location         String?        @db.VarChar(150)
  isRemote         Boolean        @default(false)
  startDate        DateTime       @db.Date
  endDate          DateTime?      @db.Date
  currentlyWorking Boolean        @default(false)
  responsibilities String?        @db.Text
  achievements     String?        @db.Text
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@index([userId, startDate])
}

model CandidateCertification {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  name          String    @db.VarChar(200)
  issuer        String    @db.VarChar(200)
  issueDate     DateTime  @db.Date
  expiryDate    DateTime? @db.Date
  doesNotExpire Boolean   @default(false)
  credentialId  String?   @db.VarChar(150)
  credentialUrl String?   @db.VarChar(500)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@index([userId, issueDate])
}

model CandidateTraining {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  title          String   @db.VarChar(200)
  provider       String   @db.VarChar(200)
  completionDate DateTime @db.Date
  durationHours  Decimal? @db.Decimal(7, 1)
  description    String?  @db.Text
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@index([userId, completionDate])
}

enum CandidateDiscoverability {
  PRIVATE
  LINK_ONLY
  PLATFORM_DISCOVERABLE
}

enum CandidateSectionVisibility {
  HIDDEN
  PLATFORM_ONLY
  PUBLIC
}

model CandidateProfilePrivacy {
  id                              String                     @id @default(uuid()) @db.Uuid
  userId                          String                     @unique @db.Uuid
  overallDiscoverability          CandidateDiscoverability   @default(PRIVATE)
  basicProfile                    CandidateSectionVisibility @default(PLATFORM_ONLY)
  locationAndPreferences          CandidateSectionVisibility @default(HIDDEN)
  education                       CandidateSectionVisibility @default(PLATFORM_ONLY)
  workExperience                  CandidateSectionVisibility @default(PLATFORM_ONLY)
  skillsAndLanguages              CandidateSectionVisibility @default(PLATFORM_ONLY)
  certificationsAndTraining       CandidateSectionVisibility @default(PLATFORM_ONLY)
  achievementsAndLinks            CandidateSectionVisibility @default(PLATFORM_ONLY)
  leaderboardParticipationEnabled Boolean                    @default(false)
  leaderboardDisplayName          String?                    @db.VarChar(80)
  leaderboardEnabledAt            DateTime?
  policyVersion                   String                     @db.VarChar(50)
  createdAt                       DateTime                   @default(now())
  updatedAt                       DateTime                   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leaderboardParticipationEnabled])
}

enum ProfessionalLinkType {
  LINKEDIN
  GITHUB
  PORTFOLIO
  PERSONAL_WEBSITE
  BEHANCE
  DRIBBBLE
  STACK_OVERFLOW
  MEDIUM
  YOUTUBE
  OTHER
}

model CandidateProfileShareToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @unique @db.Uuid
  tokenHash String    @unique @db.VarChar(128)
  enabled   Boolean   @default(true)
  rotatedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([enabled])
}

model CandidateAchievement {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  title        String    @db.VarChar(200)
  issuer       String?   @db.VarChar(200)
  achievedAt   DateTime? @db.Date
  description  String?   @db.Text
  referenceUrl String?   @db.VarChar(500)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@index([userId, achievedAt])
}

model CandidateProfessionalLink {
  id            String               @id @default(uuid()) @db.Uuid
  userId        String               @db.Uuid
  type          ProfessionalLinkType
  label         String?              @db.VarChar(100)
  url           String               @db.VarChar(500)
  normalizedUrl String               @db.VarChar(500)
  sortOrder     Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedUrl])
  @@index([userId, sortOrder])
}

model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @db.VarChar(64)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@index([userId])
  @@index([expiresAt])
}

enum DataExportStatus {
  PENDING
  PROCESSING
  READY
  FAILED
  EXPIRED
  CANCELLED
}

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  RETIRED
}

enum AssessmentVisibility {
  CANDIDATE_CATALOG
  INVITE_ONLY
  INTERNAL
}

enum AssessmentDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum AssessmentType {
  PRACTICE
  CERTIFICATION
  SCREENING
  SKILL_CHECK
}

enum AssessmentAvailability {
  AVAILABLE
  COMING_SOON
  UNAVAILABLE
}

model AssessmentCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(120)
  slug        String   @unique @db.VarChar(140)
  description String?  @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assessments Assessment[]
  questions   AssessmentQuestion[]

  @@index([isActive, sortOrder])
}

model Assessment {
  id                       String                 @id @default(uuid()) @db.Uuid
  categoryId               String                 @db.Uuid
  title                    String                 @db.VarChar(200)
  slug                     String                 @unique @db.VarChar(220)
  shortDescription         String                 @db.VarChar(500)
  description              String?                @db.Text
  instructions             String?                @db.Text
  type                     AssessmentType
  difficulty               AssessmentDifficulty
  status                   AssessmentStatus       @default(DRAFT)
  visibility               AssessmentVisibility   @default(CANDIDATE_CATALOG)
  availability             AssessmentAvailability @default(COMING_SOON)
  estimatedDurationMinutes Int
  passingScorePercentage   Int                    @default(60)
  maximumAttempts          Int?
  retakeEnabled            Boolean                @default(false)
  retakeCooldownHours      Int                    @default(0)
  certificateEnabled       Boolean                @default(false)
  certificateValidityDays  Int?
  totalPoints              Decimal                @default(0) @db.Decimal(10, 2)
  questionCount            Int                    @default(0)
  publishedAt              DateTime?
  archivedAt               DateTime?
  publicationVersion       Int                    @default(0)
  createdById              String?                @db.Uuid
  updatedById              String?                @db.Uuid
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  category               AssessmentCategory             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sections               AssessmentSection[]
  assignments            AssessmentQuestionAssignment[]
  attempts               AssessmentAttempt[]
  assessmentCertificates AssessmentCertificate[]

  @@index([status, visibility, availability])
  @@index([categoryId, status])
  @@index([difficulty, type])
  @@index([publishedAt])
}

model AssessmentSection {
  id           String   @id @default(uuid()) @db.Uuid
  assessmentId String   @db.Uuid
  title        String   @db.VarChar(200)
  description  String?  @db.Text
  instructions String?  @db.Text
  sortOrder    Int
  isRequired   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment Assessment                     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questions  AssessmentQuestionAssignment[]

  @@unique([assessmentId, sortOrder])
  @@index([assessmentId])
}

model AssessmentQuestionAssignment {
  id           String   @id @default(uuid()) @db.Uuid
  assessmentId String   @db.Uuid
  sectionId    String   @db.Uuid
  questionId   String   @db.Uuid
  sortOrder    Int
  points       Decimal  @db.Decimal(8, 2)
  isRequired   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  section    AssessmentSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  question   AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([assessmentId, questionId])
  @@unique([sectionId, sortOrder])
  @@index([assessmentId, sectionId])
  @@index([questionId])
}

model CandidateDataExportRequest {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @db.Uuid
  status          DataExportStatus @default(PENDING)
  storageKey      String?          @db.VarChar(500)
  fileSizeBytes   BigInt?
  checksumSha256  String?          @db.VarChar(64)
  requestedAt     DateTime         @default(now())
  processingAt    DateTime?
  completedAt     DateTime?
  expiresAt       DateTime?
  failedAt        DateTime?
  failureCategory String?          @db.VarChar(100)
  downloadedAt    DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, requestedAt])
  @@index([status, expiresAt])
}

enum AssessmentQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_TEXT
}

enum AssessmentQuestionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model AssessmentQuestion {
  id               String                   @id @default(uuid()) @db.Uuid
  categoryId       String                   @db.Uuid
  type             AssessmentQuestionType
  status           AssessmentQuestionStatus @default(DRAFT)
  difficulty       AssessmentDifficulty
  prompt           String                   @db.Text
  explanation      String?                  @db.Text
  acceptedAnswers  String[]
  tags             String[]
  sourceReference  String?                  @db.VarChar(300)
  estimatedSeconds Int?
  createdById      String?                  @db.Uuid
  updatedById      String?                  @db.Uuid
  archivedAt       DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  category    AssessmentCategory             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  options     AssessmentQuestionOption[]
  assignments AssessmentQuestionAssignment[]

  @@index([categoryId, status])
  @@index([type, difficulty, status])
  @@index([createdAt])
}

model AssessmentQuestionOption {
  id         String   @id @default(uuid()) @db.Uuid
  questionId String   @db.Uuid
  label      String   @db.Text
  isCorrect  Boolean  @default(false)
  sortOrder  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, sortOrder])
  @@index([questionId])
}

enum AssessmentAttemptStatus {
  IN_PROGRESS
  EXPIRED
  SUBMITTED
  CANCELLED
}

enum AssessmentAttemptResultStatus {
  PASSED
  FAILED
}

enum AssessmentAttemptFinalizationReason {
  CANDIDATE_SUBMITTED
  DEADLINE_REACHED
  ADMIN_FINALIZED
}

model AssessmentAttempt {
  id                           String                               @id @default(uuid()) @db.Uuid
  assessmentId                 String                               @db.Uuid
  candidateId                  String                               @db.Uuid
  attemptNumber                Int                                  @default(1)
  assessmentPublicationVersion Int
  assessmentTitleSnapshot      String                               @db.VarChar(200)
  assessmentSlugSnapshot       String                               @db.VarChar(220)
  instructionsSnapshot         String?                              @db.Text
  durationMinutesSnapshot      Int
  passingScoreSnapshot         Int
  totalPointsSnapshot          Decimal                              @db.Decimal(10, 2)
  questionCountSnapshot        Int
  status                       AssessmentAttemptStatus              @default(IN_PROGRESS)
  finalizationReason           AssessmentAttemptFinalizationReason?
  scoreEarned                  Decimal?                             @db.Decimal(10, 2)
  scorePossible                Decimal?                             @db.Decimal(10, 2)
  scorePercentage              Decimal?                             @db.Decimal(5, 2)
  resultStatus                 AssessmentAttemptResultStatus?
  correctCount                 Int?
  incorrectCount               Int?
  unansweredCount              Int?
  scoringVersion               Int?
  scoringCompletedAt           DateTime?
  startedAt                    DateTime                             @default(now())
  deadlineAt                   DateTime
  lastActivityAt               DateTime                             @default(now())
  expiredAt                    DateTime?
  submittedAt                  DateTime?
  createdAt                    DateTime                             @default(now())
  updatedAt                    DateTime                             @updatedAt

  assessment            Assessment                  @relation(fields: [assessmentId], references: [id], onDelete: Restrict)
  candidate             User                        @relation(fields: [candidateId], references: [id], onDelete: Restrict)
  sections              AssessmentAttemptSection[]
  questions             AssessmentAttemptQuestion[]
  answers               AssessmentAttemptAnswer[]
  assessmentCertificate AssessmentCertificate?

  @@unique([candidateId, assessmentId, attemptNumber])
  @@index([candidateId, status])
  @@index([assessmentId, candidateId])
  @@index([status, deadlineAt])
  @@index([status, scoringCompletedAt])
}

model AssessmentAttemptSection {
  id                   String   @id @default(uuid()) @db.Uuid
  attemptId            String   @db.Uuid
  sourceSectionId      String?  @db.Uuid
  titleSnapshot        String   @db.VarChar(200)
  descriptionSnapshot  String?  @db.Text
  instructionsSnapshot String?  @db.Text
  sortOrder            Int
  isRequired           Boolean  @default(true)
  createdAt            DateTime @default(now())

  attempt   AssessmentAttempt           @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questions AssessmentAttemptQuestion[]

  @@unique([attemptId, sortOrder])
  @@index([attemptId])
}

model AssessmentAttemptQuestion {
  id                  String                 @id @default(uuid()) @db.Uuid
  attemptId           String                 @db.Uuid
  attemptSectionId    String                 @db.Uuid
  sourceQuestionId    String?                @db.Uuid
  typeSnapshot        AssessmentQuestionType
  promptSnapshot      String                 @db.Text
  explanationSnapshot String?                @db.Text
  acceptedAnswersJson Json?
  pointsSnapshot      Decimal                @db.Decimal(8, 2)
  isRequired          Boolean                @default(true)
  sortOrder           Int
  createdAt           DateTime               @default(now())

  attempt AssessmentAttempt                 @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  section AssessmentAttemptSection          @relation(fields: [attemptSectionId], references: [id], onDelete: Cascade)
  options AssessmentAttemptQuestionOption[]
  answer  AssessmentAttemptAnswer?

  @@unique([attemptId, sourceQuestionId])
  @@unique([attemptSectionId, sortOrder])
  @@index([attemptId])
}

model AssessmentAttemptQuestionOption {
  id                String   @id @default(uuid()) @db.Uuid
  attemptQuestionId String   @db.Uuid
  sourceOptionId    String?  @db.Uuid
  labelSnapshot     String   @db.Text
  isCorrectSnapshot Boolean
  sortOrder         Int
  createdAt         DateTime @default(now())

  question AssessmentAttemptQuestion @relation(fields: [attemptQuestionId], references: [id], onDelete: Cascade)

  @@unique([attemptQuestionId, sortOrder])
  @@index([attemptQuestionId])
}

enum AssessmentCertificateStatus {
  PENDING
  GENERATING
  READY
  FAILED
  REVOKED
  EXPIRED
}

model AssessmentCertificate {
  id                      String                      @id @default(uuid()) @db.Uuid
  candidateId             String                      @db.Uuid
  assessmentId            String                      @db.Uuid
  attemptId               String                      @unique @db.Uuid
  certificateNumber       String                      @unique @db.VarChar(80)
  verificationCodeHash    String                      @unique @db.VarChar(128)
  verificationCodeHint    String?                     @db.VarChar(20)
  status                  AssessmentCertificateStatus @default(PENDING)
  holderNameSnapshot      String                      @db.VarChar(200)
  assessmentTitleSnapshot String                      @db.VarChar(200)
  assessmentSlugSnapshot  String                      @db.VarChar(220)
  scorePercentageSnapshot Decimal                     @db.Decimal(5, 2)
  issuedAt                DateTime?
  expiresAt               DateTime?
  generatedAt             DateTime?
  failedAt                DateTime?
  failureCategory         String?                     @db.VarChar(100)
  revokedAt               DateTime?
  storageKey              String?                     @db.VarChar(500)
  fileSizeBytes           BigInt?
  checksumSha256          String?                     @db.VarChar(64)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  candidate  User              @relation(fields: [candidateId], references: [id], onDelete: Restrict)
  assessment Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Restrict)
  attempt    AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Restrict)

  @@index([candidateId, status, issuedAt])
  @@index([assessmentId, issuedAt])
  @@index([status, expiresAt])
}

model AssessmentAttemptAnswer {
  id                String    @id @default(uuid()) @db.Uuid
  attemptId         String    @db.Uuid
  attemptQuestionId String    @unique @db.Uuid
  selectedOptionIds String[]
  shortTextAnswer   String?   @db.Text
  awardedPoints     Decimal?  @db.Decimal(8, 2)
  isCorrect         Boolean?
  scoredAt          DateTime?
  answeredAt        DateTime?
  lastSavedAt       DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  attempt  AssessmentAttempt         @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question AssessmentAttemptQuestion @relation(fields: [attemptQuestionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}

enum MfaStatus {
  DISABLED
  PENDING
  ENABLED
}

model UserMfa {
  id                       String    @id @default(uuid()) @db.Uuid
  userId                   String    @unique @db.Uuid
  status                   MfaStatus @default(DISABLED)
  encryptedTotpSecret      String?   @db.Text
  secretEncryptionVersion  Int?
  enrollmentExpiresAt      DateTime?
  enabledAt                DateTime?
  disabledAt               DateTime?
  lastVerifiedAt           DateTime?
  recoveryCodesGeneratedAt DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MfaRecoveryCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  codeHash  String    @unique @db.VarChar(255)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

enum MfaChallengeStatus {
  PENDING
  VERIFIED
  EXPIRED
  CONSUMED
  REVOKED
}

model MfaChallenge {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @db.Uuid
  status             MfaChallengeStatus @default(PENDING)
  challengeTokenHash String             @unique @db.VarChar(255)
  expiresAt          DateTime
  verifiedAt         DateTime?
  consumedAt         DateTime?
  failedAttempts     Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt])
}

model MfaTrustedDevice {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  tokenHash      String    @unique @db.VarChar(255)
  deviceName     String?   @db.VarChar(120)
  browserSummary String?   @db.VarChar(200)
  trustedAt      DateTime  @default(now())
  lastUsedAt     DateTime?
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
}

enum ExpertApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
  WITHDRAWN
}

enum ExpertVerificationDocumentType {
  GOVERNMENT_ID
  PROFESSIONAL_CERTIFICATE
  EMPLOYMENT_PROOF
  EDUCATION_CERTIFICATE
  OTHER_SUPPORTING_DOCUMENT
}

model ExpertProfile {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @unique @db.Uuid
  professionalTitle   String    @db.VarChar(150)
  professionalSummary String    @db.Text
  yearsOfExperience   Int
  currentCompany      String?   @db.VarChar(150)
  currentPosition     String?   @db.VarChar(150)
  highestEducation    String?   @db.VarChar(200)
  linkedinUrl         String?   @db.VarChar(500)
  portfolioUrl        String?   @db.VarChar(500)
  personalWebsiteUrl  String?   @db.VarChar(500)
  interviewLanguages  Json
  countryId           String    @db.Uuid
  city                String?   @db.VarChar(120)
  profilePhotoFileId  String?   @db.Uuid
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications ExpertApplication[]

  @@index([countryId])
}

model ExpertApplication {
  id                String                  @id @default(uuid()) @db.Uuid
  userId            String                  @db.Uuid
  expertProfileId   String                  @db.Uuid
  status            ExpertApplicationStatus @default(DRAFT)
  submissionVersion Int                     @default(0)
  submittedAt       DateTime?
  reviewStartedAt   DateTime?
  reviewedAt        DateTime?
  reviewedById      String?                 @db.Uuid
  decisionReasonCode String?                @db.VarChar(100)
  reviewerNote      String?                 @db.Text
  applicantResponse String?                 @db.Text
  approvedAt        DateTime?
  rejectedAt        DateTime?
  withdrawnAt       DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  user          User                          @relation(fields: [userId], references: [id], onDelete: Restrict)
  expertProfile ExpertProfile                 @relation(fields: [expertProfileId], references: [id], onDelete: Restrict)
  documents     ExpertVerificationDocument[]

  @@index([userId, status])
  @@index([status, submittedAt])
  @@index([reviewedById, reviewedAt])
}

model ExpertVerificationDocument {
  id              String                         @id @default(uuid()) @db.Uuid
  applicationId   String                         @db.Uuid
  type            ExpertVerificationDocumentType
  storageKey      String                         @unique @db.VarChar(500)
  originalFileName String                        @db.VarChar(255)
  mimeType        String                         @db.VarChar(120)
  sizeBytes       BigInt
  checksumSha256  String                         @db.VarChar(64)
  uploadedAt      DateTime                       @default(now())
  removedAt       DateTime?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  application ExpertApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, type, removedAt])
}
