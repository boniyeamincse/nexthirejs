  @@unique([userId, expertiseAreaId])
  @@index([userId, isPrimary])
  @@index([expertiseAreaId])
}

enum ExpertServiceType {
  MOCK_INTERVIEW
  CV_REVIEW
  CAREER_COACHING
  TECHNICAL_INTERVIEW_PREPARATION
  BEHAVIORAL_INTERVIEW_PREPARATION
  PORTFOLIO_REVIEW
}

enum ExpertServiceStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

model ExpertService {
  id                      String              @id @default(uuid()) @db.Uuid
  userId                  String              @db.Uuid
  expertiseAreaId         String              @db.Uuid
  type                    ExpertServiceType
  title                   String              @db.VarChar(150)
  shortDescription        String              @db.VarChar(300)
  detailedDescription     String              @db.Text
  durationMinutes         Int
  priceAmount             Decimal             @db.Decimal(12, 2)
  priceCurrency           String              @db.Char(3)
  languageCodes           String[]
  preparationInstructions String?             @db.Text
  status                  ExpertServiceStatus @default(DRAFT)
  activatedAt             DateTime?
  deactivatedAt           DateTime?
  archivedAt              DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  expertiseArea ExpertiseArea @relation(fields: [expertiseAreaId], references: [id], onDelete: Restrict)
  bookings      ExpertBooking[]

  @@index([userId, status])
  @@index([expertiseAreaId, status])
  @@index([type, status])
}

model ExpertAvailabilityProfile {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @unique @db.Uuid
  timezone            String   @db.VarChar(100)
  bufferBeforeMinutes Int      @default(0)
  bufferAfterMinutes  Int      @default(0)
  minimumNoticeHours  Int      @default(12)
  bookingWindowDays   Int      @default(30)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user      User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekly    ExpertWeeklyAvailability[]
  overrides ExpertAvailabilityOverride[]
}

model ExpertWeeklyAvailability {
  id                    String   @id @default(uuid()) @db.Uuid
  availabilityProfileId String   @db.Uuid
  dayOfWeek             Int
  startLocalTime        String   @db.VarChar(5)
  endLocalTime          String   @db.VarChar(5)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  availabilityProfile ExpertAvailabilityProfile @relation(fields: [availabilityProfileId], references: [id], onDelete: Cascade)

  @@index([availabilityProfileId, dayOfWeek])
}

enum ExpertAvailabilityOverrideType {
  UNAVAILABLE
  CUSTOM_HOURS
}

model ExpertAvailabilityOverride {
  id                    String                         @id @default(uuid()) @db.Uuid
  availabilityProfileId String                         @db.Uuid
  localDate             String                         @db.VarChar(10)
  type                  ExpertAvailabilityOverrideType
  reason                String?                        @db.VarChar(300)
  windows               Json?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt

  availabilityProfile ExpertAvailabilityProfile @relation(fields: [availabilityProfileId], references: [id], onDelete: Cascade)

  @@unique([availabilityProfileId, localDate])
  @@index([availabilityProfileId, localDate])
}

enum ExpertBookingStatus {
  HELD
  CONFIRMED
  CANCELLED
  EXPIRED
  COMPLETED
}

/// A reservation of a computed ExpertSlotService slot against an ExpertService.
/// Created as HELD with a holdExpiresAt while the candidate finalizes the
/// booking (payment is not yet implemented, NH-M29 — confirm() stands in for
/// that step for now); a delayed BullMQ job expires unconfirmed holds so the
/// slot is released. A partial unique index (see migration SQL) on
/// (expertUserId, slotStartUtc) where status is HELD/CONFIRMED is the
/// authoritative race guard against double-booking the same slot.
model ExpertBooking {
  id              String              @id @default(uuid()) @db.Uuid
  expertUserId    String              @db.Uuid
  expertServiceId String              @db.Uuid
  candidateId     String              @db.Uuid
  status          ExpertBookingStatus @default(HELD)
  slotStartUtc    DateTime
  slotEndUtc      DateTime
  holdExpiresAt   DateTime?
  meetingUrl      String?             @db.VarChar(500)
  notes           String?             @db.Text
  cancelledAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  expertUser    User          @relation("ExpertBookingExpert", fields: [expertUserId], references: [id], onDelete: Cascade)
  expertService ExpertService @relation(fields: [expertServiceId], references: [id], onDelete: Restrict)
  candidate     User          @relation("ExpertBookingCandidate", fields: [candidateId], references: [id], onDelete: Cascade)
  evaluation    ExpertSessionEvaluation?
  review        ExpertReview?

  @@index([expertUserId, status])
  @@index([candidateId, status])
  @@index([slotStartUtc])
}

/// NH-M16: the expert's private feedback on the candidate's session performance
/// (mock-interview coaching notes), visible only to that candidate — not a
/// public review of the expert. See ExpertReview for the reverse direction.
model ExpertSessionEvaluation {
  id                 String   @id @default(uuid()) @db.Uuid
  bookingId          String   @unique @db.Uuid
  expertUserId       String   @db.Uuid
  candidateId        String   @db.Uuid
  communication      Int
  technicalKnowledge Int
  confidence         Int
  problemSolving     Int
  overallScore       Int
  strengths          String?  @db.Text
  improvements       String?  @db.Text
  nextSteps          String?  @db.Text
  submittedAt        DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  booking    ExpertBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  expertUser User          @relation("ExpertSessionEvaluationExpert", fields: [expertUserId], references: [id], onDelete: Cascade)
  candidate  User          @relation("ExpertSessionEvaluationCandidate", fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([expertUserId])
  @@index([candidateId])
}

/// NH-M16: the candidate's public review/rating of the expert after a
/// COMPLETED booking — the aggregate-rating data source NH-M13 deferred
/// (it shipped with no fabricated ratings since none existed yet).
/// isHidden/hiddenAt/hiddenReason are the "moderation hooks" from the spec;
/// a full moderation center is NH-M32's scope, not built here.
model ExpertReview {
  id           String    @id @default(uuid()) @db.Uuid
  bookingId    String    @unique @db.Uuid
  expertUserId String    @db.Uuid
  candidateId  String    @db.Uuid
  rating       Int
  comment      String?   @db.Text
  isHidden     Boolean   @default(false)
  hiddenAt     DateTime?
  hiddenReason String?   @db.VarChar(300)
  submittedAt  DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  booking    ExpertBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  expertUser User          @relation("ExpertReviewExpert", fields: [expertUserId], references: [id], onDelete: Cascade)
  candidate  User          @relation("ExpertReviewCandidate", fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([expertUserId, isHidden])
  @@index([candidateId])
}

/// NH-M17: an expert's earnings wallet, keyed directly to their userId (no
/// TrainerProfile indirection like the legacy WalletAccount). Balance is
/// real, not fabricated — nothing credits it yet because there is no
/// payment-capture domain (NH-M29) to source real earnings from. The ledger
/// plumbing (ExpertWalletLedger, recordTransaction-equivalent) exists and is
/// ready to be wired to booking payment capture once NH-M29 lands.
model ExpertWalletAccount {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String       @unique @db.Uuid
  balance       Decimal      @default(0) @db.Decimal(12, 2)
  currency      String       @db.Char(3) @default("USD")
  status        WalletStatus @default(ACTIVE)
  totalEarnings Decimal      @default(0) @db.Decimal(12, 2)
  totalPayouts  Decimal      @default(0) @db.Decimal(12, 2)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   ExpertWalletLedger[]
  payoutAccounts ExpertPayoutAccount[]

  @@index([status])
}

model ExpertWalletLedger {
  id            String          @id @default(uuid()) @db.Uuid
  walletId      String          @db.Uuid
  type          TransactionType
  amount        Decimal         @db.Decimal(12, 2)
  description   String?         @db.VarChar(200)
  bookingId     String?         @db.Uuid
  referenceId   String?         @db.VarChar(100)
  balanceBefore Decimal         @db.Decimal(12, 2)
  balanceAfter  Decimal         @db.Decimal(12, 2)
  createdAt     DateTime        @default(now())

  wallet ExpertWalletAccount @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([type, createdAt])
  @@index([bookingId])
}

model ExpertPayoutAccount {
  id            String    @id @default(uuid()) @db.Uuid
  walletId      String    @db.Uuid
  accountHolder String    @db.VarChar(200)
  accountType   String    @db.VarChar(50)
  accountNumber String    @db.VarChar(100)
  routingNumber String?   @db.VarChar(50)
  isDefault     Boolean   @default(false)
  isVerified    Boolean   @default(false)
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())

  wallet         ExpertWalletAccount   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  payoutRequests ExpertPayoutRequest[]

  @@index([walletId, isVerified])
}

model ExpertPayoutRequest {
  id              String       @id @default(uuid()) @db.Uuid
  payoutAccountId String       @db.Uuid
  amount          Decimal      @db.Decimal(12, 2)
  status          PayoutStatus @default(PENDING)
  requestedAt     DateTime     @default(now())
  processedAt     DateTime?
  completedAt     DateTime?
  failureReason   String?      @db.Text
  referenceId     String?      @db.VarChar(100)

  payoutAccount ExpertPayoutAccount @relation(fields: [payoutAccountId], references: [id], onDelete: Cascade)

  @@index([status, requestedAt])
  @@index([payoutAccountId])
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseVisibility {
  CANDIDATE_CATALOG
  PRIVATE
}

enum CourseDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum LessonContentType {
  ARTICLE
  VIDEO
}

enum CourseEnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum LessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model CourseCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(120)
  slug        String   @unique @db.VarChar(140)
  description String?  @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses Course[]

  @@index([isActive, sortOrder])
}

model Course {
  id                       String           @id @default(uuid()) @db.Uuid
  categoryId               String           @db.Uuid
  title                    String           @db.VarChar(200)
  slug                     String           @unique @db.VarChar(220)
  summary                  String           @db.VarChar(500)
  description              String?          @db.Text
  difficulty               CourseDifficulty
  status                   CourseStatus     @default(DRAFT)
  visibility               CourseVisibility @default(CANDIDATE_CATALOG)
  estimatedDurationMinutes Int              @default(0)
  moduleCount              Int              @default(0)
  lessonCount              Int              @default(0)
  publishedAt              DateTime?
  archivedAt               DateTime?
  publicationVersion       Int              @default(0)
  createdById              String?          @db.Uuid
  updatedById              String?          @db.Uuid
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  category    CourseCategory     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  modules     CourseModule[]
  enrollments CourseEnrollment[]

  @@index([status, visibility])
  @@index([categoryId, status])
  @@index([publishedAt])
}

model CourseModule {
  id          String   @id @default(uuid()) @db.Uuid
  courseId    String   @db.Uuid
  title       String   @db.VarChar(200)
  description String?  @db.Text
  sortOrder   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([courseId, sortOrder])
  @@index([courseId])
}

model Lesson {
  id              String            @id @default(uuid()) @db.Uuid
  courseModuleId  String            @db.Uuid
  title           String            @db.VarChar(200)
  contentType     LessonContentType @default(ARTICLE)
  bodyContent     String?           @db.Text
  videoUrl        String?           @db.VarChar(500)
  durationMinutes Int               @default(0)
  sortOrder       Int
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  courseModule CourseModule     @relation(fields: [courseModuleId], references: [id], onDelete: Cascade)
  progress     LessonProgress[]

  @@unique([courseModuleId, sortOrder])
  @@index([courseModuleId])
}

model CourseEnrollment {
  id                 String                 @id @default(uuid()) @db.Uuid
  candidateId        String                 @db.Uuid
  courseId           String                 @db.Uuid
  status             CourseEnrollmentStatus @default(ACTIVE)
  progressPercentage Int                    @default(0)
  enrolledAt         DateTime               @default(now())
  completedAt        DateTime?
  lastAccessedAt     DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  candidate      User             @relation(fields: [candidateId], references: [id], onDelete: Restrict)
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Restrict)
  lessonProgress LessonProgress[]

  @@unique([candidateId, courseId])
  @@index([candidateId, status])
  @@index([courseId, status])
}

model LessonProgress {
  id                  String               @id @default(uuid()) @db.Uuid
  enrollmentId        String               @db.Uuid
  lessonId            String               @db.Uuid
  status              LessonProgressStatus @default(NOT_STARTED)
  lastPositionSeconds Int?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  enrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson           @relation(fields: [lessonId], references: [id], onDelete: Restrict)

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@index([lessonId])
}

// ============================================================================
// Company Modules (NH-M19 — Company Profile and Verification)
// ============================================================================

enum CompanyVerificationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
  WITHDRAWN
}

enum CompanyDocumentType {
  BUSINESS_REGISTRATION
  TAX_CERTIFICATE
  AUTHORIZATION_LETTER
  OTHER_SUPPORTING_DOCUMENT
}

/// NH-M19: one company per owning user for now — team/multi-member support
/// (invites, additional member roles) is NH-M20's scope, not built here.
model Company {
  id                    String   @id @default(uuid()) @db.Uuid
  ownerUserId           String   @unique @db.Uuid
  name                  String   @db.VarChar(200)
  legalName             String?  @db.VarChar(200)
  website               String?  @db.VarChar(500)
  industry              String?  @db.VarChar(150)
  companySize           String?  @db.VarChar(50)
  headquartersCountryId String   @db.Uuid
  headquartersCity      String?  @db.VarChar(120)
  description           String   @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  owner       User                            @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  application CompanyVerificationApplication?

  @@index([ownerUserId])
}

model CompanyVerificationApplication {
  id                 String                    @id @default(uuid()) @db.Uuid
  companyId          String                    @unique @db.Uuid
  status             CompanyVerificationStatus @default(DRAFT)
  submissionVersion  Int                       @default(0)
  submittedAt        DateTime?
  reviewStartedAt    DateTime?
  reviewedAt         DateTime?
  reviewedById       String?                   @db.Uuid
  decisionReasonCode String?                   @db.VarChar(100)
  reviewerNote       String?                   @db.Text
  applicantResponse  String?                   @db.Text
  approvedAt         DateTime?
  rejectedAt         DateTime?
  withdrawnAt        DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  company   Company                       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  documents CompanyVerificationDocument[]

  @@index([status, submittedAt])
  @@index([reviewedById, reviewedAt])
}

model CompanyVerificationDocument {
  id               String              @id @default(uuid()) @db.Uuid
  applicationId    String              @db.Uuid
  type             CompanyDocumentType
  storageKey       String              @unique @db.VarChar(500)
  originalFileName String              @db.VarChar(255)
  mimeType         String              @db.VarChar(120)
  sizeBytes        BigInt
  checksumSha256   String              @db.VarChar(64)
  uploadedAt       DateTime            @default(now())
  removedAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  application CompanyVerificationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, type, removedAt])
}
