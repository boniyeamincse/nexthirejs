generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AuditActorType {
  ANONYMOUS
  USER
  SYSTEM
  INTERNAL
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  DENIED
}

model AuditLog {
  id          String         @id @default(uuid()) @db.Uuid
  occurredAt  DateTime       @default(now())
  requestId   String?        @db.VarChar(100)
  actorType   AuditActorType
  actorUserId String?        @db.Uuid
  action      String         @db.VarChar(150)
  targetType  String?        @db.VarChar(100)
  targetId    String?        @db.VarChar(100)
  outcome     AuditOutcome   @default(SUCCESS)
  metadata    Json?
  createdAt   DateTime       @default(now())

  @@index([occurredAt])
  @@index([actorUserId, occurredAt])
  @@index([action, occurredAt])
  @@index([targetType, targetId])
  @@index([requestId])
}

enum UserStatus {
  PENDING_VERIFICATION
  PROFILE_SETUP
  ACTIVE
  SUSPENDED
  DELETED
}

model User {
  id                 String     @id @default(uuid()) @db.Uuid
  email              String     @unique @db.VarChar(320)
  phone              String?    @db.VarChar(20)
  passwordHash       String
  status             UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt    DateTime?
  phoneVerifiedAt    DateTime?
  passwordChangedAt  DateTime?
  deactivatedAt      DateTime?
  deactivationReason String?    @db.VarChar(100)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  roles                     UserRole[]
  sessions                  UserSession[]
  emailVerificationTokens   EmailVerificationToken[]
  phoneVerificationOtps     PhoneVerificationOtp[]
  passwordResetTokens       PasswordResetToken[]
  candidateProfile          CandidateProfile?
  candidatePreference       CandidatePreference?
  cvs                       Cv[]
  projects                  Project[]
  trainerProfile            TrainerProfile?
  bookingsAsCandidate       Booking[]
  educationRecords          EducationRecord[]
  workExperienceRecords     WorkExperienceRecord[]
  skills                    CandidateSkill[]
  languages                 CandidateLanguage[]
  certifications            CandidateCertification[]
  training                  CandidateTraining[]
  achievements              CandidateAchievement[]
  careerPassport            CareerPassport?
  professionalLinks         CandidateProfessionalLink[]
  profilePrivacy            CandidateProfilePrivacy?
  shareToken                CandidateProfileShareToken?
  dataExportRequests        CandidateDataExportRequest[]
  assessmentAttempts        AssessmentAttempt[]
  assessmentCertificates    AssessmentCertificate[]
  courseEnrollments         CourseEnrollment[]
  mfa                       UserMfa?
  mfaRecoveryCodes          MfaRecoveryCode[]
  mfaChallenges             MfaChallenge[]
  mfaTrustedDevices         MfaTrustedDevice[]
  expertExpertise           ExpertExpertise[]
  expertServices            ExpertService[]
  expertAvailabilityProfile ExpertAvailabilityProfile?
  expertProfile             ExpertProfile?
  expertApplications        ExpertApplication[]
  expertBookingsAsExpert    ExpertBooking[]            @relation("ExpertBookingExpert")
  expertBookingsAsCandidate ExpertBooking[]            @relation("ExpertBookingCandidate")
  sessionEvaluationsGiven   ExpertSessionEvaluation[]  @relation("ExpertSessionEvaluationExpert")
  sessionEvaluationsReceived ExpertSessionEvaluation[] @relation("ExpertSessionEvaluationCandidate")
  expertReviewsReceived     ExpertReview[]             @relation("ExpertReviewExpert")
  expertReviewsGiven        ExpertReview[]             @relation("ExpertReviewCandidate")
  expertWallet              ExpertWalletAccount?
  company                   Company?
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users UserRole[]
}

model UserRole {
  userId     String   @db.Uuid
  roleId     String   @db.Uuid
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([userId, roleId])
  @@index([roleId])
}

enum UserSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
  COMPROMISED
}

model UserSession {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @db.Uuid
  status           UserSessionStatus @default(ACTIVE)
  refreshTokenHash String            @unique @db.VarChar(128)
  tokenFamilyId    String            @db.Uuid
  expiresAt        DateTime
  lastUsedAt       DateTime?
  ipAddress        String?           @db.VarChar(64)
  userAgent        String?           @db.VarChar(512)
  browserName      String?           @db.VarChar(100)
  operatingSystem  String?           @db.VarChar(100)
  deviceType       String?           @db.VarChar(30)
  revokedAt        DateTime?
  revokeReason     String?           @db.VarChar(100)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, lastUsedAt])
  @@index([tokenFamilyId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @db.VarChar(64)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@index([userId])
  @@index([expiresAt])
}

model PhoneVerificationOtp {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  phone        String    @db.VarChar(20)
  otpHash      String    @db.VarChar(64)
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int       @default(0)
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phone, expiresAt])
  @@index([expiresAt])
}

model CandidateProfile {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @unique @db.Uuid
  fullName             String    @db.VarChar(150)
  professionalHeadline String?   @db.VarChar(160)
  professionalSummary  String?   @db.Text
  dateOfBirth          DateTime? @db.Date
  completionPercentage Int       @default(0)
  photoStorageKey      String?   @db.VarChar(255)
  photoMimeType        String?   @db.VarChar(50)
  photoSizeBytes       Int?
  photoUpdatedAt       DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fullName])
}

model Country {
  id                 String   @id @default(uuid()) @db.Uuid
  code               String   @unique @db.Char(2)
  name               String   @db.VarChar(100)
  phoneCode          String   @db.VarChar(10)
  defaultCurrency    String   @db.Char(3)
  defaultTimezone    String   @db.VarChar(100)
  supportedLanguages String[]
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  candidatePreferences CandidatePreference[]

  @@index([isActive, sortOrder])
}

model CareerGoal {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?  @db.Text
  icon        String?  @db.VarChar(50)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidatePreferences CandidatePreference[]

  @@index([isActive, sortOrder])
}

enum WorkMode {
  ONSITE
  HYBRID
  REMOTE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

model CandidatePreference {
  id                       String           @id @default(uuid()) @db.Uuid
  userId                   String           @unique @db.Uuid
  countryId                String           @db.Uuid
  careerGoalId             String?          @db.Uuid
  currentCity              String           @db.VarChar(100)
  preferredJobRoles        String[]
  preferredWorkModes       WorkMode[]
  preferredEmploymentTypes EmploymentType[]
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  country    Country     @relation(fields: [countryId], references: [id], onDelete: Restrict)
  careerGoal CareerGoal? @relation(fields: [careerGoalId], references: [id], onDelete: SetNull)

  @@index([countryId])
  @@index([careerGoalId])
}

enum EducationLevel {
  SECONDARY
  HIGHER_SECONDARY
  DIPLOMA
  BACHELOR
  MASTER
  DOCTORATE
  PROFESSIONAL
  OTHER
}

model EducationRecord {
  id                String         @id @default(uuid()) @db.Uuid
  userId            String         @db.Uuid
  educationLevel    EducationLevel
  institutionName   String         @db.VarChar(200)
  qualification     String         @db.VarChar(150)
  fieldOfStudy      String?        @db.VarChar(150)
  startDate         DateTime       @db.Date
  endDate           DateTime?      @db.Date
  currentlyStudying Boolean        @default(false)
  grade             String?        @db.VarChar(100)
  description       String?        @db.Text
  sortOrder         Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@index([userId, startDate])
}

enum SkillLevel {
  BEGINNER
  DEVELOPING
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum LanguageProficiency {
  BASIC
  CONVERSATIONAL
  PROFESSIONAL
  FLUENT
  NATIVE
}

model CandidateSkill {
  id                String     @id @default(uuid()) @db.Uuid
  userId            String     @db.Uuid
  name              String     @db.VarChar(100)
  normalizedName    String     @db.VarChar(100)
  level             SkillLevel
  yearsOfExperience Decimal?   @db.Decimal(4, 1)
  sortOrder         Int        @default(0)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId, sortOrder])
}

model CandidateLanguage {
  id             String              @id @default(uuid()) @db.Uuid
  userId         String              @db.Uuid
  name           String              @db.VarChar(100)
  normalizedName String              @db.VarChar(100)
  speaking       LanguageProficiency
  reading        LanguageProficiency
  writing        LanguageProficiency
  sortOrder      Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId, sortOrder])
}

model WorkExperienceRecord {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String         @db.Uuid
  companyName      String         @db.VarChar(200)
  jobTitle         String         @db.VarChar(150)
  employmentType   EmploymentType
  location         String?        @db.VarChar(150)
  isRemote         Boolean        @default(false)
  startDate        DateTime       @db.Date
  endDate          DateTime?      @db.Date
  currentlyWorking Boolean        @default(false)
  responsibilities String?        @db.Text
  achievements     String?        @db.Text
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@index([userId, startDate])
}

model CandidateCertification {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  name          String    @db.VarChar(200)
  issuer        String    @db.VarChar(200)
  issueDate     DateTime  @db.Date
  expiryDate    DateTime? @db.Date
  doesNotExpire Boolean   @default(false)
  credentialId  String?   @db.VarChar(150)
  credentialUrl String?   @db.VarChar(500)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@index([userId, issueDate])
}

model CandidateTraining {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  title          String   @db.VarChar(200)
  provider       String   @db.VarChar(200)
  completionDate DateTime @db.Date
  durationHours  Decimal? @db.Decimal(7, 1)
  description    String?  @db.Text
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@index([userId, completionDate])
}

enum CandidateDiscoverability {
  PRIVATE
  LINK_ONLY
  PLATFORM_DISCOVERABLE
}

enum CandidateSectionVisibility {
  HIDDEN
  PLATFORM_ONLY
  PUBLIC
}

model CandidateProfilePrivacy {
  id                              String                     @id @default(uuid()) @db.Uuid
  userId                          String                     @unique @db.Uuid
  overallDiscoverability          CandidateDiscoverability   @default(PRIVATE)
  basicProfile                    CandidateSectionVisibility @default(PLATFORM_ONLY)
  locationAndPreferences          CandidateSectionVisibility @default(HIDDEN)
  education                       CandidateSectionVisibility @default(PLATFORM_ONLY)
  workExperience                  CandidateSectionVisibility @default(PLATFORM_ONLY)
  skillsAndLanguages              CandidateSectionVisibility @default(PLATFORM_ONLY)
  certificationsAndTraining       CandidateSectionVisibility @default(PLATFORM_ONLY)
  achievementsAndLinks            CandidateSectionVisibility @default(PLATFORM_ONLY)
  leaderboardParticipationEnabled Boolean                    @default(false)
  leaderboardDisplayName          String?                    @db.VarChar(80)
  leaderboardEnabledAt            DateTime?
  policyVersion                   String                     @db.VarChar(50)
  createdAt                       DateTime                   @default(now())
  updatedAt                       DateTime                   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leaderboardParticipationEnabled])
}

enum ProfessionalLinkType {
  LINKEDIN
  GITHUB
  PORTFOLIO
  PERSONAL_WEBSITE
  BEHANCE
  DRIBBBLE
  STACK_OVERFLOW
  MEDIUM
  YOUTUBE
  OTHER
}

model CandidateProfileShareToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @unique @db.Uuid
  tokenHash String    @unique @db.VarChar(128)
  enabled   Boolean   @default(true)
  rotatedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([enabled])
}

enum CvTemplate {
  MODERN
  CLASSIC
  MINIMAL
  ATS_OPTIMIZED
}

enum CvVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

model Cv {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @db.Uuid
  title           String       @db.VarChar(200)
  template        CvTemplate   @default(ATS_OPTIMIZED)
  visibility      CvVisibility @default(PRIVATE)
  isDefault       Boolean      @default(false)
  completionScore Int          @default(0)
  jobPostingId    String?      @db.Uuid
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  sections        CvSection[]
  sectionContents CvSectionContent[]
  versions        CvVersion[]
  exports         CvExport[]

  @@index([userId, isDefault])
  @@index([visibility])
  @@index([createdAt])
}

model CvSection {
  id        String  @id @default(uuid()) @db.Uuid
  cvId      String  @db.Uuid
  type      String  @db.VarChar(50)
  title     String  @db.VarChar(100)
  enabled   Boolean @default(true)
  sortOrder Int     @default(0)

  cv Cv @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@unique([cvId, type])
  @@index([cvId, sortOrder])
}

model CvSectionContent {
  id          String   @id @default(uuid()) @db.Uuid
  cvId        String   @db.Uuid
  sectionType String   @db.VarChar(50)
  content     Json
  updatedAt   DateTime @updatedAt

  cv Cv @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@unique([cvId, sectionType])
  @@index([cvId])
}

model CvVersion {
  id            String   @id @default(uuid()) @db.Uuid
  cvId          String   @db.Uuid
  versionNumber Int      @default(1)
  content       Json
  createdAt     DateTime @default(now())

  cv Cv @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId, versionNumber])
}

enum CvExportStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

model CvExport {
  id              String         @id @default(uuid()) @db.Uuid
  cvId            String         @db.Uuid
  userId          String         @db.Uuid
  status          CvExportStatus @default(PENDING)
  storageKey      String?        @db.VarChar(255)
  checksumSha256  String?        @db.VarChar(64)
  fileSizeBytes   Int?
  failureCategory String?        @db.VarChar(100)
  requestedAt     DateTime       @default(now())
  generatedAt     DateTime?
  failedAt        DateTime?

  cv Cv @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId, requestedAt])
  @@index([userId, requestedAt])
}

enum ProjectStatus {
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  ABANDONED
}

enum ProjectVerificationLevel {
  SELF_SUBMITTED
  IDENTITY_CONFIRMED
  TRAINER_REVIEWED
  EXPERT_VERIFIED
  COMPANY_REVIEWED
  FEATURED
}

enum ProjectVisibility {
  PRIVATE
  TRAINER_ONLY
  COMPANIES_ONLY
  PUBLIC
}

model Project {
  id                    String                   @id @default(uuid()) @db.Uuid
  userId                String                   @db.Uuid
  title                 String                   @db.VarChar(200)
  summary               String                   @db.VarChar(500)
  description           String                   @db.Text
  problemStatement      String?                  @db.Text
  solution              String?                  @db.Text
  candidateContribution String?                  @db.Text
  status                ProjectStatus            @default(IN_PROGRESS)
  visibility            ProjectVisibility        @default(PRIVATE)
  verificationLevel     ProjectVerificationLevel @default(SELF_SUBMITTED)
  startDate             DateTime?                @db.Date
  completionDate        DateTime?                @db.Date
  teamSize              Int?
  roleInProject         String?                  @db.VarChar(100)
  githubUrl             String?                  @db.VarChar(500)
  liveUrl               String?                  @db.VarChar(500)
  documentationUrl      String?                  @db.VarChar(500)
  challenges            String?                  @db.Text
  lessonsLearned        String?                  @db.Text
  futureImprovements    String?                  @db.Text
  completionScore       Int                      @default(0)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  technologies  ProjectTechnology[]
  media         ProjectMedia[]
  verifications ProjectVerification[]
  reports       ProjectReport[]

  @@index([userId, visibility])
  @@index([verificationLevel])
  @@index([createdAt])
}

model ProjectTechnology {
  id        String @id @default(uuid()) @db.Uuid
  projectId String @db.Uuid
  name      String @db.VarChar(100)
  category  String @db.VarChar(50)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
}

model ProjectMedia {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  type      String   @db.VarChar(20)
  url       String   @db.VarChar(500)
  caption   String?  @db.VarChar(200)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
}

model ProjectVerification {
  id                String    @id @default(uuid()) @db.Uuid
  projectId         String    @db.Uuid
  verifiedBy        String?   @db.Uuid
  verificationLevel String    @db.VarChar(50)
  verifiedAt        DateTime?
  comment           String?   @db.Text
  createdAt         DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, verificationLevel])
}

model ProjectReport {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @db.Uuid
  reason     String   @db.VarChar(200)
  details    String?  @db.Text
  reportedBy String   @db.Uuid
  status     String   @default("PENDING") @db.VarChar(20)
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}

enum TrainerVerificationStatus {
  PENDING_REVIEW
  VERIFIED
  REJECTED
  SUSPENDED
}

enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  PAYMENT_PROCESSING
  CONFIRMED
  RESCHEDULED
  CANCELLED
  NO_SHOW
  COMPLETED
  DISPUTED
}

model TrainerProfile {
  id                  String                    @id @default(uuid()) @db.Uuid
  userId              String                    @unique @db.Uuid
  headline            String                    @db.VarChar(160)
  bio                 String?                   @db.Text
  profileImage        String?                   @db.VarChar(500)
  verificationStatus  TrainerVerificationStatus @default(PENDING_REVIEW)
  verifiedAt          DateTime?
  responseTimeMinutes Int                       @default(24)
  averageRating       Decimal                   @default(0) @db.Decimal(3, 2)
  totalSessions       Int                       @default(0)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  services     TrainerService[]
  packages     TrainerPackage[]
  availability AvailabilityRule[]
  bookings     Booking[]
  evaluations  Evaluation[]
  wallet       WalletAccount?

  @@index([verificationStatus])
  @@index([averageRating])
}

model TrainerService {
  id          String   @id @default(uuid()) @db.Uuid
  trainerId   String   @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.Text
  category    String   @db.VarChar(50)
  basePrice   Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD") @db.Char(3)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  trainer  TrainerProfile   @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  packages TrainerPackage[]

  @@index([trainerId])
  @@index([category])
}

model TrainerPackage {
  id             String   @id @default(uuid()) @db.Uuid
  trainerId      String   @db.Uuid
  serviceId      String   @db.Uuid
  title          String   @db.VarChar(200)
  description    String?  @db.Text
  numSessions    Int
  duration       Int
  price          Decimal  @db.Decimal(10, 2)
  currency       String   @default("USD") @db.Char(3)
  includesReview Boolean  @default(false)
  includesReport Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  trainer  TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  service  TrainerService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([trainerId])
  @@index([serviceId])
}

model AvailabilityRule {
  id          String   @id @default(uuid()) @db.Uuid
  trainerId   String   @db.Uuid
  dayOfWeek   Int
  startTime   String   @db.VarChar(5)
  endTime     String   @db.VarChar(5)
  timezone    String   @db.VarChar(50)
  isRecurring Boolean  @default(true)
  createdAt   DateTime @default(now())

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId, dayOfWeek])
}

model Booking {
  id           String        @id @default(uuid()) @db.Uuid
  trainerId    String        @db.Uuid
  packageId    String        @db.Uuid
  candidateId  String        @db.Uuid
  status       BookingStatus @default(PENDING_PAYMENT)
  scheduledAt  DateTime
  endTime      DateTime
  meetingUrl   String?       @db.VarChar(500)
