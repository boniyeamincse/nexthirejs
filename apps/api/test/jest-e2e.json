{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@nexthire/(.*)$": "<rootDir>/../../../packages/$1/src",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
